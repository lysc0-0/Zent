<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme using Material 3 -->
    <style name="Theme.Zent" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/zent_primary_gold</item>
        <item name="colorOnPrimary">@color/zent_button_text_dark</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/zent_background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
